<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sourcelin.blog.mapper.FriendLinkMapper">
    
    <resultMap type="FriendLink" id="FriendLinkResult">
        <result property="id"    column="id"    />
        <result property="name"    column="name"    />
        <result property="avatar"    column="avatar"    />
        <result property="avatarFileId"    column="avatar_file_id"    />
        <result property="url"    column="url"    />
        <result property="description"    column="description"    />
        <result property="cover"    column="cover"    />
        <result property="email"    column="email"    />
        <result property="orderNum"    column="order_num"    />
        <result property="label"    column="label"    />
        <result property="category"    column="category"    />
        <result property="status"    column="status"    />
        <result property="reason"    column="reason"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectFriendLinkVo">
        select id, name, avatar, avatar_file_id, url, description, cover, email, order_num, label, category, status, reason, create_time, update_time, remark from b_friend_link
    </sql>

    <select id="selectFriendLinkList" parameterType="FriendLink" resultMap="FriendLinkResult">
        <include refid="selectFriendLinkVo"/>
        <where>  
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
            <if test="category != null "> and category = #{category}</if>
            <if test="status != null "> and status = #{status}</if>
        </where>
        order by order_num asc, id asc
    </select>
    
    <select id="selectFriendLinkById" parameterType="Long" resultMap="FriendLinkResult">
        <include refid="selectFriendLinkVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertFriendLink" parameterType="FriendLink" useGeneratedKeys="true" keyProperty="id">
        insert into b_friend_link
        <trim prefix="(" suffix=")" suffixOverrides=",">
            name,
            url,
            <if test="avatar != null">avatar,</if>
            <if test="avatarFileId != null">avatar_file_id,</if>
            <if test="description != null">description,</if>
            <if test="cover != null">cover,</if>
            <if test="email != null">email,</if>
            <if test="orderNum != null">order_num,</if>
            <if test="label != null">label,</if>
            <if test="category != null">category,</if>
            <if test="status != null">status,</if>
            <if test="reason != null">reason,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
         <trim prefix="values (" suffix=")" suffixOverrides=",">
            #{name},
            #{url},
            <if test="avatar != null">#{avatar},</if>
            <if test="avatarFileId != null">#{avatarFileId},</if>
            <if test="description != null">#{description},</if>
            <if test="cover != null">#{cover},</if>
            <if test="email != null">#{email},</if>
            <if test="orderNum != null">#{orderNum},</if>
            <if test="label != null">#{label},</if>
            <if test="category != null">#{category},</if>
            <if test="status != null">#{status},</if>
            <if test="reason != null">#{reason},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateFriendLink" parameterType="FriendLink">
        update b_friend_link
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null">name = #{name},</if>
            <if test="avatar != null">avatar = #{avatar},</if>
            <if test="avatarFileId != null">avatar_file_id = #{avatarFileId},</if>
            <if test="url != null">url = #{url},</if>
            <if test="description != null">description = #{description},</if>
            <if test="cover != null">cover = #{cover},</if>
            <if test="email != null">email = #{email},</if>
            <if test="orderNum != null">order_num = #{orderNum},</if>
            <if test="label != null">label = #{label},</if>
            <if test="category != null">category = #{category},</if>
            <if test="status != null">status = #{status},</if>
            <if test="reason != null">reason = #{reason},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteFriendLinkById" parameterType="Long">
        delete from b_friend_link where id = #{id}
    </delete>

    <delete id="deleteFriendLinkByIds" parameterType="String">
        delete from b_friend_link where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
