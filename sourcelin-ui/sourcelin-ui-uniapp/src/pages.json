{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue",
      "^s-(.*)": "@/components/s-$1/s-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/home/home",
      "style": {
        "navigationStyle": "custom",
        "enablePullDownRefresh": true
      }
    },
    {
      "path": "pages/discover/discover",
      "style": {
        "navigationBarTitleText": "发现",
        "enablePullDownRefresh": true
      }
    },
    {
      "path": "pages/community/community",
      "style": {
        "navigationBarTitleText": "圈子",
        "enablePullDownRefresh": true
      }
    },
    {
      "path": "pages/mine/mine",
      "style": {
        "navigationStyle": "custom"
      }
    }
  ],
  "subPackages": [
    {
      "root": "pages-article",
      "pages": [
        {
          "path": "detail/detail",
          "style": { "navigationBarTitleText": "文章详情" }
        },
        {
          "path": "list/list",
          "style": { "navigationBarTitleText": "文章列表", "enablePullDownRefresh": true }
        },
        {
          "path": "search/search",
          "style": { "navigationBarTitleText": "搜索" }
        }
      ]
    },
    {
      "root": "pages-user",
      "pages": [
        {
          "path": "login/login",
          "style": { "navigationBarTitleText": "登录" }
        },
        {
          "path": "profile/profile",
          "style": { "navigationBarTitleText": "个人资料" }
        },
        {
          "path": "settings/settings",
          "style": { "navigationBarTitleText": "体验设置" }
        },
        {
          "path": "interactions/interactions",
          "style": { "navigationBarTitleText": "我的互动", "enablePullDownRefresh": true }
        },
        {
          "path": "collects/collects",
          "style": { "navigationBarTitleText": "我的收藏", "enablePullDownRefresh": true }
        },
        {
          "path": "follows/follows",
          "style": { "navigationBarTitleText": "关注与粉丝", "enablePullDownRefresh": true }
        },
        {
          "path": "articles/articles",
          "style": { "navigationBarTitleText": "我的文章", "enablePullDownRefresh": true }
        },
        {
          "path": "home/home",
          "style": { "navigationBarTitleText": "用户主页" }
        }
      ]
    },
    {
      "root": "pages-messages",
      "pages": [
        {
          "path": "index/index",
          "style": { "navigationBarTitleText": "消息中心", "enablePullDownRefresh": true }
        },
        {
          "path": "detail/detail",
          "style": { "navigationBarTitleText": "消息详情" }
        }
      ]
    },
    {
      "root": "pages-about",
      "pages": [
        {
          "path": "index/index",
          "style": { "navigationBarTitleText": "关于本站" }
        },
        {
          "path": "policies/policies",
          "style": { "navigationBarTitleText": "协议与政策" }
        },
        {
          "path": "policy/policy",
          "style": { "navigationBarTitleText": "政策详情" }
        },
        {
          "path": "links/links",
          "style": { "navigationBarTitleText": "友情链接" }
        },
        {
          "path": "navigation/navigation",
          "style": { "navigationBarTitleText": "网站导航" }
        }
      ]
    },
    {
      "root": "pages-publish",
      "pages": [
        {
          "path": "say/say",
          "style": { "navigationBarTitleText": "发布说说" }
        },
        {
          "path": "treehole/treehole",
          "style": { "navigationBarTitleText": "树洞投递" }
        },
        {
          "path": "article/article",
          "style": { "navigationBarTitleText": "写文章" }
        }
      ]
    }
  ],
  "preloadRule": {
    "pages/home/home": {
      "network": "all",
      "packages": ["pages-article"]
    },
    "pages/mine/mine": {
      "network": "all",
      "packages": ["pages-user"]
    },
    "pages/discover/discover": {
      "network": "all",
      "packages": ["pages-about"]
    }
  },
  "globalStyle": {
    "navigationBarTextStyle": "@navigationBarTextStyle",
    "navigationBarTitleText": "Sourcelin",
    "navigationBarBackgroundColor": "@navigationBarBackgroundColor",
    "backgroundColor": "@backgroundColor",
    "backgroundColorTop": "@backgroundColor",
    "backgroundColorBottom": "@backgroundColor",
    "backgroundTextStyle": "@backgroundTextStyle",
    "onReachBottomDistance": 80,
    "pageOrientation": "portrait"
  },
  "tabBar": {
    "color": "@tabBarColor",
    "selectedColor": "@tabBarSelectedColor",
    "backgroundColor": "@tabBarBackgroundColor",
    "borderStyle": "@tabBarBorderStyle",
    "list": [
      {
        "pagePath": "pages/home/home",
        "text": "首页",
        "iconPath": "static/tabbar/home.png",
        "selectedIconPath": "static/tabbar/home-active.png"
      },
      {
        "pagePath": "pages/discover/discover",
        "text": "发现",
        "iconPath": "static/tabbar/discover.png",
        "selectedIconPath": "static/tabbar/discover-active.png"
      },
      {
        "pagePath": "pages/mine/mine",
        "text": "我的",
        "iconPath": "static/tabbar/mine.png",
        "selectedIconPath": "static/tabbar/mine-active.png"
      }
    ]
  },
  "condition": {
    "current": 0,
    "list": [
      {
        "name": "首页",
        "path": "pages/home/home",
        "query": ""
      }
    ]
  }
}
