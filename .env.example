DATA_ROOT=/home/sourcelin/deploy/data
JAR_ROOT=/home/sourcelin/deploy/jars
LOG_ROOT=/home/sourcelin/deploy/logs

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=replace-with-your-mysql-password
NACOS_DB_NAME=sourcelin-config

NACOS_SERVER_ADDR=127.0.0.1:8848
NACOS_GROUP=BLOG_GROUP
NACOS_USERNAME=replace-with-your-nacos-username
NACOS_PASSWORD=replace-with-your-nacos-password

NACOS_AUTH_TOKEN=replace-with-a-strong-base64-token
NACOS_AUTH_IDENTITY_KEY=replace-with-a-random-identity-key
NACOS_AUTH_IDENTITY_VALUE=replace-with-a-random-identity-value
